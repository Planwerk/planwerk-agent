{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewResult",
  "description": "Contract for the `review` and `audit` --format json output (report.ReviewResult). The audit path reuses ReviewResult, so both commands share this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["findings", "summary", "recommendation"],
  "properties": {
    "findings": {
      "description": "Findings ordered by severity. Encoded as null (not []) when there are none.",
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/finding" }
    },
    "summary": { "type": "string" },
    "recommendation": { "type": "string" },
    "gates": {
      "description": "Per-run counts for the review's two demotion gates. The counts describe the whole run, not the filtered finding list. Absent when neither gate ran, or on results produced before gate recording existed; an absent gate object means 'not recorded', not 'nothing demoted'.",
      "$ref": "#/$defs/gateStats"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "title", "file", "problem", "action"],
      "properties": {
        "id": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["BLOCKING", "CRITICAL", "WARNING", "INFO"]
        },
        "title": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "line_end": { "type": "integer" },
        "pattern": { "type": "string" },
        "actionability": {
          "type": "string",
          "enum": ["auto-fix", "needs-discussion", "architectural"]
        },
        "fix_class": {
          "type": "string",
          "enum": ["AUTO-FIX", "ASK"]
        },
        "confidence": {
          "type": "string",
          "enum": ["verified", "likely", "uncertain"]
        },
        "problem": { "type": "string" },
        "action": { "type": "string" },
        "code_snippet": { "type": "string" },
        "suggested_fix": { "type": "string" },
        "fix_options": {
          "type": "array",
          "items": { "$ref": "#/$defs/fixOption" }
        },
        "recommended_option": { "type": "string" },
        "recommendation_reasoning": { "type": "string" },
        "related_to": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confirmed_by": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification_note": { "type": "string" },
        "snippet_check": {
          "description": "The snippet gate's per-finding record: 'passed' or a 'demoted: <reason>' string. Set by the pipeline, never by the model.",
          "type": "string"
        },
        "claim_check": {
          "description": "The claim gate's per-finding record. Set by the pipeline, never by the model.",
          "type": "string",
          "enum": ["confirmed", "refuted", "no-verdict"]
        }
      }
    },
    "gateStats": {
      "type": "object",
      "additionalProperties": false,
      "description": "Per-run counts for each demotion gate. A missing gate object means the gate never ran this run.",
      "properties": {
        "snippet": { "$ref": "#/$defs/snippetGateStats" },
        "claim": { "$ref": "#/$defs/claimGateStats" }
      }
    },
    "snippetGateStats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["examined", "demoted"],
      "properties": {
        "examined": { "type": "integer" },
        "demoted": { "type": "integer" }
      }
    },
    "claimGateStats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sent", "verdicts", "refuted"],
      "properties": {
        "sent": { "type": "integer" },
        "verdicts": { "type": "integer" },
        "refuted": { "type": "integer" }
      }
    },
    "fixOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "approach"],
      "properties": {
        "id": { "type": "string" },
        "approach": { "type": "string" },
        "pros": { "type": "string" },
        "cons": { "type": "string" },
        "effort": { "type": "string" },
        "risk_if_skipped": { "type": "string" }
      }
    }
  }
}
